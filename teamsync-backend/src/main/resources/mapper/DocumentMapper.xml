<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.teamsync.mapper.DocumentMapper">
    <resultMap id="docMap" type="Document">
        <id column="id" property="id"/>
        <result column="project_id" property="projectId"/>
        <result column="name" property="name"/>
        <result column="file_path" property="filePath"/>
        <result column="file_url" property="fileUrl"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_type" property="fileType"/>
        <result column="uploader_id" property="uploaderId"/>
        <result column="category" property="category"/>
        <result column="download_count" property="downloadCount"/>
        <result column="create_time" property="createTime"/>
        <result column="uploader_name" property="uploaderName"/>
    </resultMap>
    <select id="findById" resultMap="docMap">SELECT d.*, u.username as uploader_name FROM document d LEFT JOIN user u ON d.uploader_id=u.id WHERE d.id=#{id}</select>
    <select id="findByProjectId" resultMap="docMap">SELECT d.*, u.username as uploader_name FROM document d LEFT JOIN user u ON d.uploader_id=u.id WHERE d.project_id=#{projectId} ORDER BY d.create_time DESC</select>
    <select id="findAll" resultMap="docMap">SELECT d.*, u.username as uploader_name FROM document d LEFT JOIN user u ON d.uploader_id=u.id ORDER BY d.create_time DESC</select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">INSERT INTO document(project_id,name,file_path,file_url,file_size,file_type,uploader_id,category) VALUES(#{projectId},#{name},#{filePath},#{fileUrl},#{fileSize},#{fileType},#{uploaderId},#{category})</insert>
    <delete id="deleteById">DELETE FROM document WHERE id=#{id}</delete>
    <update id="incrementDownloadCount">UPDATE document SET download_count=download_count+1 WHERE id=#{id}</update>
</mapper>
