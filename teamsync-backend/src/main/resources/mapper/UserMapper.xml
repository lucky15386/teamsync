<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.teamsync.mapper.UserMapper">
    <resultMap id="userMap" type="User">
        <id column="id" property="id"/><result column="username" property="username"/><result column="password" property="password"/><result column="real_name" property="realName"/><result column="role" property="role"/><result column="avatar" property="avatar"/><result column="email" property="email"/><result column="phone" property="phone"/><result column="status" property="status"/><result column="create_time" property="createTime"/><result column="update_time" property="updateTime"/>
    </resultMap>
    <select id="findByUsername" resultMap="userMap">SELECT * FROM user WHERE username=#{username}</select>
    <select id="findById" resultMap="userMap">SELECT * FROM user WHERE id=#{id}</select>
    <select id="findAll" resultMap="userMap">SELECT * FROM user ORDER BY create_time DESC</select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">INSERT INTO user(username,password,real_name,role,avatar,email,phone,status) VALUES(#{username},#{password},#{realName},#{role},#{avatar},#{email},#{phone},#{status})</insert>
    <update id="update">UPDATE user <set><if test="realName!=null">real_name=#{realName},</if><if test="role!=null">role=#{role},</if><if test="avatar!=null">avatar=#{avatar},</if><if test="email!=null">email=#{email},</if><if test="phone!=null">phone=#{phone},</if><if test="password!=null and password!=''">password=#{password},</if></set> WHERE id=#{id}</update>
    <update id="updateStatus">UPDATE user SET status=#{status} WHERE id=#{id}</update>
    <delete id="deleteById">DELETE FROM user WHERE id=#{id}</delete>
</mapper>
